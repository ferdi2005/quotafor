<%= form_with model: recurring_activity, local: true do |f| %>
  <% if recurring_activity.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% recurring_activity.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :topic, "Argomento", class: "form-label" %>
      <%= f.select :topic,
            options_for_select(enum_options(RecurringActivity, :topic), recurring_activity.topic),
            {},
            class: "form-select" %>
    </div>

    <div class="col-md-3">
      <%= f.label :periodicity, "Periodicità", class: "form-label" %>
      <%= f.select :periodicity,
            options_for_select(enum_options(RecurringActivity, :periodicity), recurring_activity.periodicity),
            {},
            class: "form-select" %>
    </div>

    <div class="col-md-3">
      <%= f.label :weekday, "Giorno", class: "form-label" %>
      <%= f.select :weekday,
            options_for_select(enum_options(RecurringActivity, :weekday), recurring_activity.weekday),
            {},
            class: "form-select" %>
    </div>

    <div class="col-md-3">
      <%= f.label :starts_at, "Orario inizio", class: "form-label" %>
      <%= f.time_field :starts_at, class: "form-control", value: recurring_activity.starts_at&.strftime("%H:%M") %>
    </div>

    <div class="col-md-3">
      <%= f.label :ends_at, "Orario fine", class: "form-label" %>
      <%= f.time_field :ends_at, class: "form-control", value: recurring_activity.ends_at&.strftime("%H:%M") %>
    </div>

    <div class="col-md-6">
      <%= f.label :location, "Luogo", class: "form-label" %>
      <%= f.text_field :location, class: "form-control", placeholder: "Opzionale" %>
    </div>

    <div class="col-12">
      <%= f.label :notes, "Note", class: "form-label" %>
      <%= f.text_area :notes, class: "form-control", rows: 3 %>
    </div>

    <div class="col-12">
      <div class="form-check">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, "Attiva", class: "form-check-label" %>
      </div>
    </div>

    <div class="col-12 d-flex gap-2">
      <%= f.submit recurring_activity.new_record? ? "Crea attività" : "Salva modifiche", class: "btn btn-primary" %>
      <%= link_to "Annulla", recurring_activities_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
<% end %>
