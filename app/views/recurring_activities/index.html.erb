<div class="row g-3">
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h4 mb-1">Attività ricorrenti</h1>
          <p class="text-muted mb-0">Impegni fissi settimanali o periodici.</p>
        </div>
        <%= link_to "Nuova attività", new_recurring_activity_path, class: "btn btn-primary" %>
      </div>
    </div>
  </div>

  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Argomento</th>
                <th>Periodicità</th>
                <th>Giorno</th>
                <th>Orario</th>
                <th>Luogo</th>
                <th>Stato</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% if @recurring_activities.any? %>
                <% @recurring_activities.each do |activity| %>
                  <tr>
                    <td><%= activity.topic %></td>
                    <td><%= enum_t(activity, :periodicity) %></td>
                    <td><%= enum_t(activity, :weekday) %></td>
                    <td><%= activity.starts_at.strftime("%H:%M") %> – <%= activity.ends_at.strftime("%H:%M") %></td>
                    <td><%= activity.location.presence || "-" %></td>
                    <td>
                      <% if activity.active? %>
                        <span class="badge bg-success">Attiva</span>
                      <% else %>
                        <span class="badge bg-secondary">Inattiva</span>
                      <% end %>
                    </td>
                    <td class="text-end">
                      <%= link_to "Modifica", edit_recurring_activity_path(activity), class: "btn btn-sm btn-outline-secondary me-1" %>
                      <%= button_to "Elimina", recurring_activity_path(activity), method: :delete,
                            data: { turbo_confirm: "Eliminare questa attività ricorrente?" },
                            class: "btn btn-sm btn-outline-danger" %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="7" class="text-center text-muted py-4">Nessuna attività ricorrente configurata.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

