<div class="row g-3">
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-body d-flex flex-wrap justify-content-between gap-2">
        <div>
          <h1 class="h4 mb-1"><%= @customer.full_name %></h1>
          <p class="text-muted mb-0">
            Tipo: <%= enum_t(@customer, :customer_type) %>
            | Professione: <%= @customer.profession.presence || "-" %>
            | Inizio rapporto: <%= l(@customer.relationship_started_on) %>
          </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <%= link_to "Nuovo appuntamento", new_customer_appointment_path(@customer), class: "btn btn-primary" %>
          <%= link_to "Nuova telefonata", new_customer_contact_call_path(@customer), class: "btn btn-outline-primary" %>
          <%= link_to "Nuovo obiettivo", new_customer_customer_objective_path(@customer), class: "btn btn-outline-primary" %>
          <%= link_to "Modifica", edit_customer_path(@customer), class: "btn btn-outline-secondary" %>
          <%= link_to "Dashboard", dashboard_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-12">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h2 class="h6">Dati personali cliente</h2>
        <div class="row g-3">
          <div class="col-md-4">
            <p class="mb-1"><strong>Età:</strong> <%= @customer.age || "-" %></p>
            <p class="mb-1"><strong>Professione:</strong> <%= @customer.profession.presence || "-" %></p>
            <p class="mb-1"><strong>Totale incassi:</strong> <%= number_to_currency(@customer.total_income) %></p>
            <p class="mb-1"><strong>Risparmio:</strong> <%= number_to_currency(@customer.savings) %></p>
          </div>
          <div class="col-md-4">
            <p class="mb-1"><strong>Livello soddisfazione:</strong> <%= @customer.satisfaction_level.present? ? "#{@customer.satisfaction_level}/10" : "-" %></p>
            <p class="mb-1"><strong>Prospettive:</strong></p>
            <p class="text-muted small"><%= @customer.prospects.presence || "-" %></p>
            <p class="mb-1"><strong>Telefono:</strong> <%= @customer.phone.presence || "-" %></p>
            <p class="mb-1"><strong>Email:</strong> <%= @customer.email.presence || "-" %></p>
          </div>
          <div class="col-md-4">
            <p class="mb-1"><strong>Passioni:</strong></p>
            <p class="text-muted small"><%= @customer.passions.presence || "-" %></p>
            <% if @customer.referred_by_customer.present? %>
              <p class="mb-1 mt-3"><strong>Referenziato da:</strong></p>
              <p class="text-muted small mb-0"><%= link_to @customer.referred_by_customer.full_name, customer_path(@customer.referred_by_customer), class: "text-decoration-none" %></p>
            <% end %>
          </div>
        </div>
        <% if @customer.personal_summary.present? %>
          <hr class="my-2">
          <p class="mb-0"><strong>Sintesi intervista:</strong></p>
          <p class="text-muted small"><%= @customer.personal_summary %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-12">
    <div class="card shadow-sm" id="referrals">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
          <h2 class="h6 mb-0">Referral generati</h2>
          <span class="badge bg-secondary"><%= @referred_customers.size %></span>
        </div>

        <% if @referred_customers.any? %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>Professione</th>
                  <th>Telefono</th>
                  <th>Email</th>
                  <th>Tipo</th>
                  <th>Data rapporto</th>
                </tr>
              </thead>
              <tbody>
                <% @referred_customers.each do |referred_customer| %>
                  <tr>
                    <td><%= link_to referred_customer.full_name, customer_path(referred_customer), class: "text-decoration-none fw-semibold" %></td>
                    <td><%= referred_customer.profession.presence || "-" %></td>
                    <td><%= referred_customer.phone.presence || "-" %></td>
                    <td><%= referred_customer.email.presence || "-" %></td>
                    <td><%= enum_t(referred_customer, :customer_type) %></td>
                    <td><%= l(referred_customer.relationship_started_on) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-muted mb-0">Nessun referral associato a questo cliente.</p>
        <% end %>
      </div>
    </div>
  </div>

  <% if @customer.spouses.any? %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h6">Moglie</h2>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>Cognome</th>
                  <th>Età</th>
                  <th>Professione</th>
                  <th>Incassi annuali</th>
                  <th>Prospettive</th>
                </tr>
              </thead>
              <tbody>
                <% @customer.spouses.each do |spouse| %>
                  <tr>
                    <td><%= spouse.first_name %></td>
                    <td><%= spouse.last_name %></td>
                    <td><%= spouse.age || "-" %></td>
                    <td><%= spouse.profession.presence || "-" %></td>
                    <td><%= spouse.annual_income.present? ? number_to_currency(spouse.annual_income) : "-" %></td>
                    <td><%= spouse.prospects.presence || "-" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @customer.children.any? %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h6">Figli</h2>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>Cognome</th>
                  <th>Età</th>
                  <th>Professione</th>
                  <th>Incassi annuali</th>
                  <th>Desideri</th>
                  <th>Soluzioni</th>
                </tr>
              </thead>
              <tbody>
                <% @customer.children.each do |child| %>
                  <tr>
                    <td><%= child.first_name %></td>
                    <td><%= child.last_name %></td>
                    <td><%= child.age || "-" %></td>
                    <td><%= child.profession.presence || "-" %></td>
                    <td><%= child.annual_income.present? ? number_to_currency(child.annual_income) : "-" %></td>
                    <td><span class="small"><%= child.desires.presence || "-" %></span></td>
                    <td><span class="small"><%= child.solutions.presence || "-" %></span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @customer.banks.any? %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h6">Banche</h2>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Banca</th>
                  <th>Perché</th>
                  <th>Uso</th>
                  <th>Cosa ha</th>
                  <th>Importo</th>
                  <th>Rendimento</th>
                  <th>Scadenze</th>
                  <th>Soddisfazione</th>
                </tr>
              </thead>
              <tbody>
                <% @customer.banks.each do |bank| %>
                  <tr>
                    <td><strong><%= bank.bank_name %></strong></td>
                    <td><small><%= bank.reason.presence || "-" %></small></td>
                    <td><small><%= bank.use.presence || "-" %></small></td>
                    <td><small><%= bank.what_has.presence || "-" %></small></td>
                    <td><%= bank.amount.present? ? number_to_currency(bank.amount) : "-" %></td>
                    <td><%= bank.rendimento.present? ? number_to_percentage(bank.rendimento, precision: 2) : "-" %></td>
                    <td><small><%= bank.deadlines.presence || "-" %></small></td>
                    <td><%= bank.satisfaction_level.present? ? "#{bank.satisfaction_level}/10" : "-" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @customer.insurances.any? %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h6">Previdenza</h2>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Perché</th>
                  <th>Obiettivo</th>
                  <th>Importo</th>
                  <th>Rendimento</th>
                  <th>Soddisfazione</th>
                </tr>
              </thead>
              <tbody>
                <% @customer.insurances.each do |insurance| %>
                  <tr>
                    <td><small><%= insurance.reason.presence || "-" %></small></td>
                    <td><small><%= insurance.objective.presence || "-" %></small></td>
                    <td><%= insurance.amount.present? ? number_to_currency(insurance.amount) : "-" %></td>
                    <td><%= insurance.rendimento.present? ? number_to_percentage(insurance.rendimento, precision: 2) : "-" %></td>
                    <td><%= insurance.satisfaction_level.present? ? "#{insurance.satisfaction_level}/10" : "-" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @customer.properties.any? %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h6">Immobili</h2>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Scopo</th>
                  <th>Indirizzo</th>
                </tr>
              </thead>
              <tbody>
                <% @customer.properties.each do |property| %>
                  <tr>
                    <td><%= enum_t(property, :purpose) %></td>
                    <td><%= property.address %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @customer.customer_expenses.any? %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
            <h2 class="h6 mb-0">Costi Sostenuti</h2>
            <div class="fw-semibold">Totale costi: <%= number_to_currency(@customer.total_expenses) %></div>
          </div>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Tipo spesa</th>
                  <th>Categoria</th>
                  <th>Importo</th>
                  <th>Descrizione</th>
                </tr>
              </thead>
              <tbody>
                <% @customer.customer_expenses.each do |expense| %>
                  <tr>
                    <td><%= expense.expense_type %></td>
                    <td><small><%= expense.category.presence ? enum_t(expense, :category) : "-" %></small></td>
                    <td><%= number_to_currency(expense.amount) %></td>
                    <td><small><%= expense.description.presence || "-" %></small></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="col-12 col-lg-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h2 class="h6 mb-0">Appuntamenti</h2>
        </div>
        <% if @appointments.any? %>
          <ul class="list-group list-group-flush">
            <% @appointments.limit(8).each do |appointment| %>
              <li class="list-group-item px-0">
                <div class="d-flex justify-content-between gap-2">
                  <div class="fw-semibold"><%= enum_t(appointment, :appointment_type) %></div>
                  <div class="d-flex flex-wrap align-items-start gap-1 flex-shrink-0">
                    <%= link_to "Modifica", edit_customer_appointment_path(@customer, appointment), class: "btn btn-sm btn-outline-secondary align-self-start" %>
                    <%= button_to "Elimina", customer_appointment_path(@customer, appointment), method: :delete,
                          data: { turbo_confirm: "Eliminare questo appuntamento?" },
                          class: "btn btn-sm btn-outline-danger align-self-start" %>
                  </div>
                </div>
                <div class="small text-muted"><%= l(appointment.starts_at, format: :short) %></div>
                <div class="small"><%= appointment.visit_feedback.presence || "Nessun feedback" %></div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">Nessun appuntamento registrato.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-6">
    <div class="card shadow-sm h-100" id="customer-objectives">
      <div class="card-body">
        <h2 class="h6">Obiettivi del cliente</h2>
        <% if @customer.customer_objectives.any? %>
          <ul class="list-group list-group-flush">
            <% @customer.customer_objectives.order(created_at: :desc).each do |obj| %>
              <li class="list-group-item px-0">
                <div class="d-flex justify-content-between gap-2">
                  <div>
                    <div class="fw-semibold"><%= obj.title %></div>
                    <div class="small"><%= obj.description.presence || "" %></div>
                    <div class="small text-muted">
                      Risorse necessarie: <%= obj.resources.presence || "-" %>
                      | Investite: <%= obj.invested_resources.present? ? number_to_currency(obj.invested_resources) : "-" %>
                      | Diminuite: <%= obj.diminished_resources.present? ? number_to_currency(obj.diminished_resources) : "-" %>
                    </div>
                  </div>
                  <div class="d-flex flex-wrap align-items-start gap-1 flex-shrink-0">
                    <span class="badge <%= obj.active? ? 'bg-success' : 'bg-secondary' %> align-self-start">
                      <%= obj.active? ? "Attivo" : "Inattivo" %>
                    </span>
                    <%= link_to "Modifica", edit_customer_customer_objective_path(@customer, obj), class: "btn btn-sm btn-outline-secondary align-self-start" %>
                    <%= button_to "Elimina", customer_customer_objective_path(@customer, obj), method: :delete,
                          data: { turbo_confirm: "Eliminare questo obiettivo?" },
                          class: "btn btn-sm btn-outline-danger" %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">Nessun obiettivo registrato.</p>
        <% end %>
        <div class="small text-muted mt-3">
          RFA previsto promotore: <strong><%= number_to_currency(@customer.user.rfa_expected) %></strong>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h2 class="h6">Telefonate</h2>
        <% if @contact_calls.any? %>
          <ul class="list-group list-group-flush">
            <% @contact_calls.limit(10).each do |call| %>
              <li class="list-group-item px-0">
                <div class="d-flex justify-content-between gap-2">
                  <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                      <span class="badge <%= contact_call_badge_class(call.call_type) %>"><%= enum_t(call, :call_type) %></span>
                      <div class="small text-muted"><%= l(call.called_at, format: :short) %></div>
                    </div>
                    <% if call.scheduled_for? %>
                      <div class="small">Prossimo contatto: <%= l(call.scheduled_for, format: :short) %></div>
                    <% end %>
                    <div class="small"><%= call.notes.presence || "Nessuna nota" %></div>
                  </div>
                  <div class="d-flex flex-wrap align-items-start gap-1 flex-shrink-0">
                    <%= link_to "Modifica", edit_customer_contact_call_path(@customer, call), class: "btn btn-sm btn-outline-secondary align-self-start" %>
                    <%= button_to "Elimina", customer_contact_call_path(@customer, call), method: :delete,
                          data: { turbo_confirm: "Eliminare questa telefonata?" },
                          class: "btn btn-sm btn-outline-danger align-self-start" %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">Nessuna telefonata registrata.</p>
        <% end %>
      </div>
    </div>
  </div>

</div>
