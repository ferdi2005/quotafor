<script>
(function () {
  function uniqueId() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2);
  }

  function addNestedItem(listId, templateId) {
    var list = document.getElementById(listId);
    var template = document.getElementById(templateId);
    if (!list || !template) return;

    var html = template.innerHTML.split('NEW_RECORD').join(uniqueId());
    list.insertAdjacentHTML('beforeend', html);
  }

  document.querySelectorAll('[data-add-nested]').forEach(function (button) {
    button.addEventListener('click', function () {
      var key = button.getAttribute('data-add-nested');
      var listId = key.replace(/_/g, '-') + '-items';
      var templateId = key.replace(/_/g, '-') + '-template';
      addNestedItem(listId, templateId);
    });
  });

  document.addEventListener('click', function (event) {
    var removeButton = event.target.closest('[data-remove-nested]');
    if (!removeButton) return;

    var item = removeButton.closest('[data-nested-item]');
    if (!item) return;

    var destroyField = item.querySelector('.nested-destroy-field');
    var persistedRecord = item.querySelector('input[name*="[id]"]');

    if (destroyField && persistedRecord) {
      destroyField.value = '1';
      item.classList.add('d-none');
      return;
    }

    item.remove();
  });
})();
</script>
