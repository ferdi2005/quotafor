<%= form_with model: customer, local: true do |f| %>
  <% if customer.errors.any? %>
    <div class="alert alert-danger mb-4">
      <ul class="mb-0">
        <% customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h1 class="h4 mb-3">Dati personali</h1>
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <%= f.label :first_name, "Nome", class: "form-label" %>
          <%= f.text_field :first_name, class: "form-control" %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :last_name, "Cognome", class: "form-label" %>
          <%= f.text_field :last_name, class: "form-control" %>
        </div>
        <div class="col-12 col-md-4">
          <%= f.label :birth_date, "Data di nascita", class: "form-label" %>
          <%= f.text_field :birth_date, class: "form-control", data: { datepicker: true }, autocomplete: "off" %>
        </div>
        <div class="col-12 col-md-4">
          <%= f.label :profession, "Professione", class: "form-label" %>
          <%= f.text_field :profession, class: "form-control" %>
        </div>
        <div class="col-12 col-md-4">
          <%= f.label :annual_income, "Reddito annuo", class: "form-label" %>
          <%= f.number_field :annual_income, step: :any, class: "form-control" %>
        </div>
        <div class="col-12 col-md-4">
          <%= f.label :relationship_started_on, "Data inizio rapporto", class: "form-label" %>
          <%= f.text_field :relationship_started_on, class: "form-control", data: { datepicker: true }, autocomplete: "off" %>
        </div>
        <div class="col-12 col-md-8">
          <%= f.label :referred_by_customer_id, "Referenziato da", class: "form-label" %>
          <%= f.select :referred_by_customer_id,
                       options_for_select(
                         @selected_referrer.present? ? [[ [@selected_referrer.full_name, @selected_referrer.phone.presence, @selected_referrer.email.presence].compact.join(" - "), @selected_referrer.id ]] : [],
                         customer.referred_by_customer_id
                       ),
                       { include_blank: "Cerca cliente referente..." },
                       class: "form-select",
                       data: {
                         referrer_select: true,
                         referrer_url: referrer_suggestions_customers_path,
                         exclude_customer_id: customer.persisted? ? customer.id : nil,
                         placeholder: "Cerca per nome, telefono o email"
                       } %>
          <div class="form-text">Cerca il cliente referente per nome, telefono o email.</div>
          <div class="mt-2" data-referrer-badge-container>
            <% if @selected_referrer.present? %>
              <span class="badge bg-info-subtle text-dark border">
                Referente selezionato:
                <%= link_to @selected_referrer.full_name, customer_path(@selected_referrer), class: "text-decoration-none" %>
              </span>
            <% end %>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :phone, "Telefono", class: "form-label" %>
          <%= f.telephone_field :phone, class: "form-control" %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, class: "form-control" %>
        </div>
        <div class="col-12 col-md-4">
          <%= f.label :customer_type, "Tipo cliente", class: "form-label" %>
          <%= f.select :customer_type,
                       options_for_select(enum_options(Customer, :customer_type), customer.customer_type),
                       {},
                       class: "form-select" %>
        </div>
        <div class="col-12 col-md-4 d-flex align-items-end">
          <div class="form-check">
            <%= f.check_box :active, class: "form-check-input" %>
            <%= f.label :active, "Cliente attivo", class: "form-check-label" %>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :satisfaction_level, "Livello soddisfazione lavoro", class: "form-label" %>
          <%= f.select :satisfaction_level,
                       options_for_select((1..10).to_a, customer.satisfaction_level),
                       { include_blank: "Seleziona..." },
                       class: "form-select" %>
        </div>
        <div class="col-12">
          <%= f.label :prospects, "Prospettive", class: "form-label" %>
          <%= f.text_area :prospects, class: "form-control", rows: 2 %>
        </div>
        <div class="col-12">
          <%= f.label :passions, "Interessi / passioni", class: "form-label" %>
          <%= f.text_area :passions, class: "form-control", rows: 2 %>
        </div>
        <div class="col-12">
          <%= f.label :personal_summary, "Sintesi colloquio", class: "form-label" %>
          <%= f.text_area :personal_summary, class: "form-control", rows: 3 %>
        </div>
      </div>
    </div>
  </div>

