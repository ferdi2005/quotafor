<% privacy_mode = privacy_mode_enabled? %>

<%= form_with model: customer, local: true do |f| %>
  <% if customer.errors.any? %>
    <div class="alert alert-danger mb-4">
      <ul class="mb-0">
        <% customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h1 class="h4 mb-3">Dati personali</h1>
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <%= f.label :first_name, "Nome", class: "form-label" %>
          <%= f.text_field :first_name, class: "form-control" %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :last_name, "Cognome", class: "form-label" %>
          <%= f.text_field :last_name, class: "form-control" %>
        </div>
        <% unless privacy_mode %>
        <div class="col-12 col-md-4">
          <%= f.label :birth_date, "Data di nascita", class: "form-label" %>
          <%= f.text_field :birth_date, class: "form-control", data: { datepicker: true }, autocomplete: "off" %>
        </div>
        <div class="col-12 col-md-4">
          <%= f.label :profession, "Professione", class: "form-label" %>
          <%= f.text_field :profession, class: "form-control" %>
        </div>
        <div class="col-12 col-md-4">
          <%= f.label :annual_income, "Reddito annuo", class: "form-label" %>
          <%= f.number_field :annual_income, step: :any, class: "form-control" %>
        </div>
        <div class="col-12 col-md-4">
          <%= f.label :relationship_started_on, "Data inizio rapporto", class: "form-label" %>
          <%= f.text_field :relationship_started_on, class: "form-control", data: { datepicker: true }, autocomplete: "off" %>
        </div>
        <% end %>
        <div class="col-12 col-md-8">
          <%= f.label :referred_by_customer_id, "Referenziato da", class: "form-label" %>
          <%= f.select :referred_by_customer_id,
                       options_for_select(
                         @selected_referrer.present? ? [[[ @selected_referrer.full_name, @selected_referrer.phone.presence, @selected_referrer.email.presence ].compact.join(" - "), @selected_referrer.id ]] : [],
                         customer.referred_by_customer_id
                       ),
                       { include_blank: "Cerca cliente referente..." },
                       class: "form-select",
                       data: {
                         referrer_select: true,
                         referrer_url: referrer_suggestions_customers_path,
                         exclude_customer_id: customer.persisted? ? customer.id : nil,
                         placeholder: "Cerca per nome, telefono o email"
                       } %>
          <div class="form-text">Cerca il cliente referente per nome, telefono o email.</div>
          <div class="mt-2" data-referrer-badge-container>
            <% if @selected_referrer.present? %>
              <span class="badge bg-info-subtle text-dark border">
                Referente selezionato:
                <%= link_to @selected_referrer.full_name, customer_path(@selected_referrer), class: "text-decoration-none" %>
              </span>
            <% end %>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :phone, "Telefono", class: "form-label" %>
          <%= f.telephone_field :phone, class: "form-control" %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, class: "form-control" %>
        </div>
        <% unless privacy_mode %>
        <div class="col-12 col-md-4">
          <%= f.label :customer_type, "Tipo cliente", class: "form-label" %>
          <%= f.select :customer_type,
                       options_for_select(enum_options(Customer, :customer_type), customer.customer_type),
                       {},
                       class: "form-select" %>
        </div>
        <div class="col-12 col-md-4 d-flex align-items-end">
          <div class="form-check">
            <%= f.check_box :active, class: "form-check-input" %>
            <%= f.label :active, "Cliente attivo", class: "form-check-label" %>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :satisfaction_level, "Livello soddisfazione lavoro", class: "form-label" %>
          <%= f.select :satisfaction_level,
                       satisfaction_level_options(customer.satisfaction_level),
                       { include_blank: "Seleziona..." },
                       class: "form-select" %>
        </div>
        <div class="col-12">
          <%= f.label :prospects, "Prospettive", class: "form-label" %>
          <%= f.text_area :prospects, class: "form-control", rows: 2 %>
        </div>
        <div class="col-12">
          <%= f.label :passions, "Interessi / passioni", class: "form-label" %>
          <%= f.text_area :passions, class: "form-control", rows: 2 %>
        </div>
        <div class="col-12">
          <%= f.label :personal_summary, "Sintesi colloquio", class: "form-label" %>
          <%= f.text_area :personal_summary, class: "form-control", rows: 3 %>
        </div>
        <% end %>
      </div>
    </div>
  </div>

  <% unless privacy_mode %>
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Moglie</h2>
      <%= f.fields_for :spouses do |spouse_form| %>
        <%= render "spouse_fields", spouse_form: spouse_form %>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Figli</h2>
        <button type="button" class="btn btn-outline-primary btn-sm" data-add-nested="children">Aggiungi figlio</button>
      </div>
      <div id="children-items">
        <%= f.fields_for :children do |child_form| %>
          <%= render "child_fields", child_form: child_form %>
        <% end %>
      </div>
    </div>
  </div>

  <template id="children-template">
    <%= f.fields_for :children, Child.new, child_index: "NEW_RECORD" do |child_form| %>
      <%= render "child_fields", child_form: child_form %>
    <% end %>
  </template>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Costi sostenuti</h2>
        <button type="button" class="btn btn-outline-primary btn-sm" data-add-nested="customer_expenses">Aggiungi costo</button>
      </div>
      <div id="customer-expenses-items">
        <%= f.fields_for :customer_expenses do |expense_form| %>
          <%= render "customer_expense_fields", expense_form: expense_form %>
        <% end %>
      </div>
    </div>
  </div>

  <template id="customer-expenses-template">
    <%= f.fields_for :customer_expenses, CustomerExpense.new, child_index: "NEW_RECORD" do |expense_form| %>
      <%= render "customer_expense_fields", expense_form: expense_form %>
    <% end %>
  </template>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Banche</h2>
        <button type="button" class="btn btn-outline-primary btn-sm" data-add-nested="banks">Aggiungi banca</button>
      </div>
      <div id="banks-items">
        <%= f.fields_for :banks do |bank_form| %>
          <%= render "bank_fields", bank_form: bank_form %>
        <% end %>
      </div>
    </div>
  </div>

  <template id="banks-template">
    <%= f.fields_for :banks, Bank.new, child_index: "NEW_RECORD" do |bank_form| %>
      <%= render "bank_fields", bank_form: bank_form %>
    <% end %>
  </template>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Investimenti con altri</h2>
        <button type="button" class="btn btn-outline-primary btn-sm" data-add-nested="investments">Aggiungi investimento</button>
      </div>
      <div id="investments-items">
        <%= f.fields_for :investments, customer.investments_with_others do |investment_form| %>
          <%= render "investment_fields", investment_form: investment_form, with_me: false, show_active: false %>
        <% end %>
      </div>
    </div>
  </div>

  <template id="investments-template">
    <%= f.fields_for :investments, Investment.new(with_me: false), child_index: "NEW_RECORD" do |investment_form| %>
      <%= render "investment_fields", investment_form: investment_form, with_me: false, show_active: false %>
    <% end %>
  </template>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Investimenti con me</h2>
        <button type="button" class="btn btn-outline-primary btn-sm" data-add-nested="investments_with_me">Aggiungi investimento</button>
      </div>
      <div id="investments-with-me-items">
        <%= f.fields_for :investments, customer.investments_with_me do |investment_form| %>
          <%= render "investment_fields", investment_form: investment_form, with_me: true, show_active: true %>
        <% end %>
      </div>
    </div>
  </div>

  <template id="investments-with-me-template">
    <%= f.fields_for :investments, Investment.new(with_me: true, active: true), child_index: "NEW_RECORD" do |investment_form| %>
      <%= render "investment_fields", investment_form: investment_form, with_me: true, show_active: true %>
    <% end %>
  </template>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Titoli</h2>
        <button type="button" class="btn btn-outline-primary btn-sm" data-add-nested="customer_titles">Aggiungi titolo</button>
      </div>
      <div id="customer-titles-items">
        <%= f.fields_for :customer_titles do |title_form| %>
          <%= render "customer_title_fields", title_form: title_form %>
        <% end %>
      </div>
    </div>
  </div>

  <template id="customer-titles-template">
    <%= f.fields_for :customer_titles, CustomerTitle.new, child_index: "NEW_RECORD" do |title_form| %>
      <%= render "customer_title_fields", title_form: title_form %>
    <% end %>
  </template>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Previdenza</h2>
        <button type="button" class="btn btn-outline-primary btn-sm" data-add-nested="insurances">Aggiungi previdenza</button>
      </div>
      <div id="insurances-items">
        <%= f.fields_for :insurances do |insurance_form| %>
          <%= render "insurance_fields", insurance_form: insurance_form %>
        <% end %>
      </div>
    </div>
  </div>

  <template id="insurances-template">
    <%= f.fields_for :insurances, Insurance.new, child_index: "NEW_RECORD" do |insurance_form| %>
      <%= render "insurance_fields", insurance_form: insurance_form %>
    <% end %>
  </template>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Immobili</h2>
        <button type="button" class="btn btn-outline-primary btn-sm" data-add-nested="properties">Aggiungi immobile</button>
      </div>
      <div id="properties-items">
        <%= f.fields_for :properties do |property_form| %>
          <%= render "property_fields", property_form: property_form %>
        <% end %>
      </div>
    </div>
  </div>

  <template id="properties-template">
    <%= f.fields_for :properties, Property.new, child_index: "NEW_RECORD" do |property_form| %>
      <%= render "property_fields", property_form: property_form %>
    <% end %>
  </template>
  <% end %>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Annulla", dashboard_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<script>
(function () {
  function italianDatepickerOptions() {
    return {
      closeText: 'Chiudi',
      prevText: 'Prec',
      nextText: 'Succ',
      currentText: 'Oggi',
      monthNames: ['Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno', 'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'],
      monthNamesShort: ['Gen', 'Feb', 'Mar', 'Apr', 'Mag', 'Giu', 'Lug', 'Ago', 'Set', 'Ott', 'Nov', 'Dic'],
      dayNames: ['Domenica', 'Lunedi', 'Martedi', 'Mercoledi', 'Giovedi', 'Venerdi', 'Sabato'],
      dayNamesShort: ['Dom', 'Lun', 'Mar', 'Mer', 'Gio', 'Ven', 'Sab'],
      dayNamesMin: ['Do', 'Lu', 'Ma', 'Me', 'Gi', 'Ve', 'Sa'],
      weekHeader: 'Sm',
      firstDay: 1,
      isRTL: false,
      showMonthAfterYear: false,
      yearSuffix: ''
    };
  }

  function initializeDatepickers(scope) {
    if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.datepicker) return;

    var locale = italianDatepickerOptions();
    var $root = scope ? window.jQuery(scope) : window.jQuery(document);
    $root.find('[data-datepicker="true"]').each(function () {
      var $input = window.jQuery(this);

      if ($input.hasClass('hasDatepicker')) return;

      $input.datepicker({
        closeText: locale.closeText,
        prevText: locale.prevText,
        nextText: locale.nextText,
        currentText: locale.currentText,
        monthNames: locale.monthNames,
        monthNamesShort: locale.monthNamesShort,
        dayNames: locale.dayNames,
        dayNamesShort: locale.dayNamesShort,
        dayNamesMin: locale.dayNamesMin,
        weekHeader: locale.weekHeader,
        firstDay: locale.firstDay,
        isRTL: locale.isRTL,
        showMonthAfterYear: locale.showMonthAfterYear,
        yearSuffix: locale.yearSuffix,
        dateFormat: 'yy-mm-dd',
        changeMonth: true,
        changeYear: true,
        yearRange: '1900:2100'
      });
    });
  }

  function initializeReferrerSelect() {
    if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.select2) return;

    var $select = window.jQuery('[data-referrer-select]');
    if (!$select.length) return;

    var $badgeContainer = window.jQuery('[data-referrer-badge-container]');

    function updateBadge(data) {
      if (!data || !data.id) {
        $badgeContainer.empty();
        return;
      }

      var safeText = data.text || 'Cliente selezionato';
      var safeUrl = data.url || ('/customers/' + data.id);

      $badgeContainer.html(
        '<span class="badge bg-info-subtle text-dark border">Referente selezionato: <a class="text-decoration-none" href="' + safeUrl + '">' + safeText + '</a></span>'
      );
    }

    $select.select2({
      width: '100%',
      allowClear: true,
      placeholder: $select.data('placeholder'),
      ajax: {
        url: $select.data('referrer-url'),
        dataType: 'json',
        delay: 250,
        data: function (params) {
          return {
            q: params.term,
            exclude_customer_id: $select.data('exclude-customer-id')
          };
        },
        processResults: function (data) {
          return { results: data.results || [] };
        }
      }
    });

    $select.on('select2:select', function (event) {
      updateBadge(event.params.data);
    });

    $select.on('select2:clear', function () {
      updateBadge(null);
    });
  }

  function uniqueId() {
    return String(Date.now()) + String(Math.floor(Math.random() * 1000000));
  }

  function addNestedItem(listId, templateId) {
    var list = document.getElementById(listId);
    var template = document.getElementById(templateId);
    if (!list || !template) return;

    var html = template.innerHTML.split('NEW_RECORD').join(uniqueId());
    list.insertAdjacentHTML('beforeend', html);

    initializeDatepickers(list);

    if (listId === 'properties-items') {
      initializePropertyInstrumentalFields(list);
    }
  }

  function setPropertyInstrumentalVisibility(select) {
    var item = select.closest('[data-nested-item]');
    if (!item) return;

    var fieldsWrapper = item.querySelector('[data-property-instrumental-fields]');
    if (!fieldsWrapper) return;

    var isInstrumental = select.value === 'instrumental';
    fieldsWrapper.classList.toggle('d-none', !isInstrumental);

    fieldsWrapper.querySelectorAll('input').forEach(function (input) {
      input.disabled = !isInstrumental;
    });
  }

  function initializePropertyInstrumentalFields(scope) {
    var root = scope || document;
    root.querySelectorAll('[data-property-purpose-select]').forEach(function (select) {
      if (!select.dataset.propertyPurposeBound) {
        select.addEventListener('change', function () {
          setPropertyInstrumentalVisibility(select);
        });
        select.dataset.propertyPurposeBound = 'true';
      }

      setPropertyInstrumentalVisibility(select);
    });
  }

  initializeDatepickers(document);
  initializeReferrerSelect();
  initializePropertyInstrumentalFields(document);

  document.querySelectorAll('[data-add-nested]').forEach(function (button) {
    button.addEventListener('click', function () {
      var key = button.getAttribute('data-add-nested');
      var listId = key.replace(/_/g, '-') + '-items';
      var templateId = key.replace(/_/g, '-') + '-template';
      addNestedItem(listId, templateId);
    });
  });

  document.addEventListener('click', function (event) {
    var removeButton = event.target.closest('[data-remove-nested]');
    if (!removeButton) return;

    var item = removeButton.closest('[data-nested-item]');
    if (!item) return;

    var destroyField = item.querySelector('.nested-destroy-field');
    var persistedRecord = item.querySelector('input[name*="[id]"]');

    if (destroyField && persistedRecord) {
      destroyField.value = '1';
      item.classList.add('d-none');
      return;
    }

    item.remove();
  });
})();
</script>
