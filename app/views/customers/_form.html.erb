<%= form_with model: customer, local: true do |f| %>
  <% if customer.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :first_name, "Nome", class: "form-label" %>
      <%= f.text_field :first_name, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :last_name, "Cognome", class: "form-label" %>
      <%= f.text_field :last_name, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :birth_date, "Data di nascita", class: "form-label" %>
      <%= f.date_field :birth_date, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :profession, "Professione", class: "form-label" %>
      <%= f.text_field :profession, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :relationship_started_on, "Data inizio rapporto", class: "form-label" %>
      <%= f.date_field :relationship_started_on, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :customer_type, "Tipo cliente", class: "form-label" %>
      <%= f.select :customer_type,
                   options_for_select([["Nuovo", "new_customer"], ["Vecchio", "existing_customer"]], customer.customer_type),
                   {},
                   class: "form-select" %>
    </div>
    <div class="col-md-6 d-flex align-items-end">
      <div class="form-check">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, "Cliente attivo", class: "form-check-label" %>
      </div>
    </div>
    <div class="col-12">
      <%= f.label :passions, "Passioni / interessi", class: "form-label" %>
      <%= f.text_area :passions, class: "form-control", rows: 2 %>
    </div>
    <div class="col-12">
      <%= f.label :personal_summary, "Sintesi intervista", class: "form-label" %>
      <%= f.text_area :personal_summary, class: "form-control", rows: 4 %>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Annulla", dashboard_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
