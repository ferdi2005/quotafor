<%= form_with model: [@customer, @appointment], local: true do |f| %>
  <% if @appointment.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @appointment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @referral_customers.present? && @referral_customers.any? { |referral_customer| referral_customer.errors.any? } %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @referral_customers.each do |referral_customer| %>
          <% referral_customer.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <%# Data e tipo %>
    <div class="col-md-6">
      <%= f.label :starts_at, "Data e ora inizio", class: "form-label" %>
      <%= f.datetime_local_field :starts_at, class: "form-control", required: true %>
    </div>
    <div class="col-md-6">
      <%= f.label :ends_at, "Data e ora fine", class: "form-label" %>
      <%= f.datetime_local_field :ends_at, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= f.label :appointment_type, "Tipologia appuntamento", class: "form-label" %>
      <%= f.select :appointment_type,
                   options_for_select([
                     ["Primo incontro", "first_meeting"],
                     ["Secondo incontro", "follow_up"],
                     ["Assistenza", "assistance"]
                   ], @appointment.appointment_type),
                   {},
                   class: "form-select", id: "appt_type_select" %>
    </div>
    <div class="col-md-6">
      <%= f.label :outcome, "Esito", class: "form-label" %>
      <%= f.select :outcome,
                   options_for_select([
                     ["Fissato ritorno", "second_visit"],
                     ["Richiamare", "call_back"],
                     ["Negativo", "negative"]
                   ], @appointment.outcome),
                   {},
                   class: "form-select", id: "appt_outcome_select" %>
    </div>

    <%# Sezione: Riunione (primo incontro, secondo incontro) %>
    <div id="section-meeting" class="col-12">
      <div class="row g-3">
        <div class="col-12">
          <%= f.label :presentation_notes, "Motivo incontro", class: "form-label" %>
          <%= f.text_area :presentation_notes, class: "form-control", rows: 2 %>
        </div>
        <div class="col-12">
          <%= f.label :visit_feedback, "Feedback visita / Esito colloquio", class: "form-label" %>
          <%= f.text_area :visit_feedback, class: "form-control", rows: 3,
                          id: "appt_visit_feedback" %>
        </div>
        <div class="col-12">
          <%= f.label :invested_resources, "Risorse investite", class: "form-label" %>
          <%= f.text_area :invested_resources, class: "form-control", rows: 2 %>
        </div>
        <div class="col-md-6">
          <%= f.label :next_appointment_at, "Prossimo appuntamento", class: "form-label" %>
          <%= f.datetime_local_field :next_appointment_at, class: "form-control" %>
        </div>
        <div class="col-md-6">
          <%= f.label :ok_current_account, "Conto corrente aperto durante la visita", class: "form-label" %>
          <%= f.select :ok_current_account,
                       options_for_select([["Sì", true], ["No", false]], @appointment.ok_current_account),
                       {},
                       class: "form-select", id: "appt_ok_current_account" %>
        </div>
        <div class="col-md-6">
          <div class="form-check mt-2">
            <%= f.check_box :awaiting_bank_transfer, class: "form-check-input", id: "appt_awaiting_bank_transfer" %>
            <%= f.label :awaiting_bank_transfer, "Attesa bonifico", class: "form-check-label" %>
          </div>
        </div>
        <div class="col-md-6">
          <%= f.label :awaiting_bank_transfer_amount, "Importo attesa bonifico (€)", class: "form-label" %>
          <%= f.number_field :awaiting_bank_transfer_amount, class: "form-control", step: "0.01", min: 0 %>
        </div>
        <div class="col-md-6">
          <div class="form-check mt-2">
            <%= f.check_box :next_appointment_callback, class: "form-check-input", id: "appt_next_appointment_callback" %>
            <%= f.label :next_appointment_callback, "Richiamare", class: "form-check-label" %>
          </div>
        </div>
      </div>
    </div>

    <%# Sezione: Assistenza %>
    <div id="section-assistance" class="col-12 d-none">
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :assistance_goal, "Obiettivo visita assistenza", class: "form-label" %>
          <%= f.text_area :assistance_goal, class: "form-control", rows: 2 %>
        </div>
        <div class="col-md-6">
          <%= f.label :technical_analysis, "Analisi tecnica prodotti", class: "form-label" %>
          <%= f.text_area :technical_analysis, class: "form-control", rows: 2 %>
        </div>
        <div class="col-12">
          <%= f.label :proposed_changes, "Modifiche proposte", class: "form-label" %>
          <%= f.text_area :proposed_changes, class: "form-control", rows: 2 %>
        </div>
      </div>
    </div>

    <%# Sezione: Motivazione esito negativo %>
    <div id="section-negative" class="col-12 d-none">
      <%= f.label :negative_reason, "Motivazione esito negativo", class: "form-label" %>
      <%= f.text_area :negative_reason, class: "form-control", rows: 2,
                      id: "appt_negative_reason" %>
    </div>

    <div class="col-12">
      <div class="card border-secondary-subtle bg-body-tertiary">
        <div class="card-body">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div>
              <h2 class="h6 mb-1">Clienti referenziati</h2>
              <p class="text-muted small mb-0">Aggiungi uno o più prospect collegati al cliente attuale.</p>
            </div>
            <button type="button" class="btn btn-outline-primary btn-sm" data-add-referral>+ Aggiungi referral</button>
          </div>

          <div id="referral-customers-items">
            <% @referral_customers.each_with_index do |referral_customer, index| %>
              <%= f.fields_for :referral_customers, referral_customer, child_index: index do |referral_form| %>
                <div class="row g-3 mb-3 p-3 border rounded bg-body" data-referral-item>
                  <div class="col-12 d-flex justify-content-between align-items-center gap-2">
                    <strong>Referral <%= index + 1 %></strong>
                    <button type="button" class="btn btn-outline-danger btn-sm" data-remove-referral>Rimuovi</button>
                  </div>
                  <div class="col-md-6">
                    <%= referral_form.label :first_name, "Nome", class: "form-label" %>
                    <%= referral_form.text_field :first_name, class: "form-control" %>
                  </div>
                  <div class="col-md-6">
                    <%= referral_form.label :last_name, "Cognome", class: "form-label" %>
                    <%= referral_form.text_field :last_name, class: "form-control" %>
                  </div>
                  <div class="col-md-6">
                    <%= referral_form.label :birth_date, "Data di nascita", class: "form-label" %>
                    <%= referral_form.date_field :birth_date, class: "form-control" %>
                  </div>
                  <div class="col-md-6">
                    <%= referral_form.label :profession, "Professione", class: "form-label" %>
                    <%= referral_form.text_field :profession, class: "form-control" %>
                  </div>
                  <div class="col-12">
                    <%= referral_form.label :personal_summary, "Note sul referral", class: "form-label" %>
                    <%= referral_form.text_area :personal_summary, class: "form-control", rows: 2 %>
                  </div>
                  <div class="col-md-6">
                    <%= referral_form.label :phone, "Telefono", class: "form-label" %>
                    <%= referral_form.telephone_field :phone, class: "form-control" %>
                  </div>
                  <div class="col-md-6">
                    <%= referral_form.label :email, "Email", class: "form-label" %>
                    <%= referral_form.email_field :email, class: "form-control" %>
                  </div>
                  <div class="col-12">
                    <%= referral_form.label :prospects, "Prospettive", class: "form-label" %>
                    <%= referral_form.text_area :prospects, class: "form-control", rows: 2 %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>

          <template id="referral-customer-template">
            <%= f.fields_for :referral_customers, Customer.new(referred_by_customer: @customer, relationship_started_on: Date.current, customer_type: :new_customer, active: true), child_index: "NEW_RECORD" do |referral_form| %>
              <div class="row g-3 mb-3 p-3 border rounded bg-body" data-referral-item>
                <div class="col-12 d-flex justify-content-between align-items-center gap-2">
                  <strong>Referral</strong>
                  <button type="button" class="btn btn-outline-danger btn-sm" data-remove-referral>Rimuovi</button>
                </div>
                <div class="col-md-6">
                  <%= referral_form.label :first_name, "Nome", class: "form-label" %>
                  <%= referral_form.text_field :first_name, class: "form-control" %>
                </div>
                <div class="col-md-6">
                  <%= referral_form.label :last_name, "Cognome", class: "form-label" %>
                  <%= referral_form.text_field :last_name, class: "form-control" %>
                </div>
                <div class="col-md-6">
                  <%= referral_form.label :birth_date, "Data di nascita", class: "form-label" %>
                  <%= referral_form.date_field :birth_date, class: "form-control" %>
                </div>
                <div class="col-md-6">
                  <%= referral_form.label :profession, "Professione", class: "form-label" %>
                  <%= referral_form.text_field :profession, class: "form-control" %>
                </div>
                <div class="col-12">
                  <%= referral_form.label :personal_summary, "Note sul referral", class: "form-label" %>
                  <%= referral_form.text_area :personal_summary, class: "form-control", rows: 2 %>
                </div>
                <div class="col-md-6">
                  <%= referral_form.label :phone, "Telefono", class: "form-label" %>
                  <%= referral_form.telephone_field :phone, class: "form-control" %>
                </div>
                <div class="col-md-6">
                  <%= referral_form.label :email, "Email", class: "form-label" %>
                  <%= referral_form.email_field :email, class: "form-control" %>
                </div>
                <div class="col-12">
                  <%= referral_form.label :prospects, "Prospettive", class: "form-label" %>
                  <%= referral_form.text_area :prospects, class: "form-control", rows: 2 %>
                </div>
              </div>
            <% end %>
          </template>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Annulla", customer_path(@customer), class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<script>
(function () {
  var typeSelect    = document.getElementById('appt_type_select');
  var outcomeSelect = document.getElementById('appt_outcome_select');
  var secMeeting    = document.getElementById('section-meeting');
  var secAssist     = document.getElementById('section-assistance');
  var secNegative   = document.getElementById('section-negative');
  var negTextarea   = document.getElementById('appt_negative_reason');
  var referralItems = document.getElementById('referral-customers-items');
  var referralTemplate = document.getElementById('referral-customer-template');

  function updateType() {
    var isAssist = typeSelect.value === 'assistance';
    secMeeting.classList.toggle('d-none', isAssist);
    secAssist.classList.toggle('d-none', !isAssist);
    updateOutcome();
  }

  function updateOutcome() {
    var outcome      = outcomeSelect.value;
    var isNegative   = outcome === 'negative';

    secNegative.classList.toggle('d-none', !isNegative);
    negTextarea.required   = isNegative;
  }

  typeSelect.addEventListener('change', updateType);
  outcomeSelect.addEventListener('change', updateOutcome);

  document.addEventListener('click', function (event) {
    var addButton = event.target.closest('[data-add-referral]');
    if (addButton && referralItems && referralTemplate) {
      var nextIndex = referralItems.querySelectorAll('[data-referral-item]').length;
      var html = referralTemplate.innerHTML.split('NEW_RECORD').join(String(nextIndex));
      referralItems.insertAdjacentHTML('beforeend', html);
      return;
    }

    var removeButton = event.target.closest('[data-remove-referral]');
    if (removeButton) {
      var item = removeButton.closest('[data-referral-item]');
      if (item && referralItems.querySelectorAll('[data-referral-item]').length > 1) {
        item.remove();
      }
    }
  });

  updateType();
})();
</script>
