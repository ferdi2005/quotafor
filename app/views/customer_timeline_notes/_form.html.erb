<%= form_with model: [@customer, timeline_note], local: true do |f| %>
  <% if timeline_note.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% timeline_note.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :happened_at, "Data e ora", class: "form-label" %>
      <%= f.datetime_local_field :happened_at, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :category, "Categoria", class: "form-label" %>
      <%= f.select :category,
            options_for_select(CustomerTimelineNote.categories.keys.map { |k| [k.humanize, k] }, timeline_note.category),
            {},
            class: "form-select" %>
    </div>
    <div class="col-12">
      <%= f.label :content, "Contenuto", class: "form-label" %>
      <%= f.text_area :content, class: "form-control", rows: 4 %>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Annulla", customer_path(@customer), class: "btn btn-outline-secondary" %>
  </div>
<% end %>
