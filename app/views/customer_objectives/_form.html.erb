<%= form_with model: [@customer, objective], local: true do |f| %>
  <% if objective.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% objective.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-12">
      <%= f.label :title, "Titolo obiettivo", class: "form-label" %>
      <%= f.text_field :title, class: "form-control" %>
    </div>
    <div class="col-12">
      <%= f.label :description, "Descrizione", class: "form-label" %>
      <%= f.text_area :description, class: "form-control", rows: 3 %>
    </div>
    <div class="col-12">
      <%= f.label :resources, "Risorse necessarie", class: "form-label" %>
      <%= f.text_area :resources, class: "form-control", rows: 2 %>
    </div>
    <div class="col-md-6">
      <%= f.label :invested_resources, "Risorse investite (€)", class: "form-label" %>
      <%= f.number_field :invested_resources, step: 0.01, min: 0, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :diminished_resources, "Risorse diminuite (€)", class: "form-label" %>
      <%= f.number_field :diminished_resources, step: 0.01, min: 0, class: "form-control" %>
    </div>
    <div class="col-12">
      <div class="form-check">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, "Attivo", class: "form-check-label" %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Annulla", customer_path(@customer), class: "btn btn-outline-secondary" %>
  </div>
<% end %>
