<%= form_with model: [:admin, user], local: true do |f| %>
  <% is_new_record = user.new_record? %>
  <% title = is_new_record ? "Nuovo utente" : "Modifica utente" %>
  <% submit_label = is_new_record ? "Crea utente" : "Salva modifiche" %>

  <% if user.errors.any? %>
    <div class="alert alert-danger mb-4">
      <ul class="mb-0">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card shadow-sm">
    <div class="card-body">
      <h1 class="h4 mb-3"><%= title %></h1>
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <%= f.label :first_name, "Nome", class: "form-label" %>
          <%= f.text_field :first_name, class: "form-control" %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :last_name, "Cognome", class: "form-label" %>
          <%= f.text_field :last_name, class: "form-control" %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, class: "form-control", required: true %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :phone, "Telefono", class: "form-label" %>
          <%= f.telephone_field :phone, class: "form-control" %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :password, "Password", class: "form-label" %>
          <%= f.password_field :password, class: "form-control", required: is_new_record %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :password_confirmation, "Conferma password", class: "form-label" %>
          <%= f.password_field :password_confirmation, class: "form-control", required: is_new_record %>
        </div>
        <% unless is_new_record %>
          <div class="col-12">
            <small class="text-muted">Lascia i campi password vuoti per mantenerla invariata.</small>
          </div>
        <% end %>
        <div class="col-12 col-md-6">
          <%= f.label :time_zone, "Fuso orario", class: "form-label" %>
          <%= f.time_zone_select :time_zone, nil, {}, { class: "form-select" } %>
        </div>
        <div class="col-12 col-md-6 d-flex flex-column justify-content-end gap-2 pb-2">
          <div class="form-check">
            <%= f.check_box :admin, class: "form-check-input" %>
            <%= f.label :admin, "Amministratore", class: "form-check-label" %>
          </div>
          <div class="form-check">
            <%= f.check_box :email_notifications, class: "form-check-input" %>
            <%= f.label :email_notifications, "Notifiche email", class: "form-check-label" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-3">
    <%= link_to "Annulla", admin_users_path, class: "btn btn-outline-secondary" %>
    <%= f.submit submit_label, class: "btn btn-primary" %>
  </div>
<% end %>
