<div class="row g-3 mb-3">
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
          <div>
            <h1 class="h4 mb-1">Gestione utenti</h1>
            <p class="text-muted mb-0">Gli amministratori possono creare e controllare gli utenti della piattaforma.</p>
          </div>
          <%= link_to "Nuovo utente", new_admin_user_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>Email</th>
                <th>Telefono</th>
                <th>Fuso</th>
                <th>Ruolo</th>
                <th>Creato il</th>
              </tr>
            </thead>
            <tbody>
              <% if @users.any? %>
                <% @users.each do |user| %>
                  <tr>
                    <td><%= user.full_name %></td>
                    <td><%= user.email %></td>
                    <td><%= user.phone.presence || "-" %></td>
                    <td><%= user.time_zone %></td>
                    <td>
                      <% if user.admin? %>
                        <span class="badge bg-danger">Admin</span>
                      <% else %>
                        <span class="badge bg-secondary">Utente</span>
                      <% end %>
                    </td>
                    <td><%= l(user.created_at, format: :short) %></td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="6" class="text-center text-muted py-4">Nessun utente presente.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
